# ESPHome build artifacts
.esphome/
**/.pioenvs/
**/.piolibdeps/
**/build/

# Secrets - NEVER commit these
secrets.yaml
**/secrets.yaml

# Custom device configs - these contain personal network info
# Use the example configs as templates
esphome/*-mini.yaml
esphome/*-minisplit.yaml
esphome/tcl-*.yaml
esphome/laser-*.yaml
!esphome/example-*.yaml

# Shared includes: keep a committed example; ignore real `device_base.yaml` (local/secrets).
esphome/01_common/*
!esphome/01_common/device_base.example.yaml

# Data analysis files (debug data, logs)
Data/

# Local firmware dumps and flash backups (large binaries)
Firmware/

# Old sniffer component (superseded by pioneer_minisplit)
esphome/sniffer/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
*.txt

# Uploads/temporary files
uploads/
